# Copy to .env and fill in. The LLM layer is OPTIONAL — the statistical core runs without any key.

# Which provider the pluggable LLM layer uses: groq | openai | ollama | anthropic
LLM_PROVIDER=groq

# API key for the chosen provider (Groq has a free tier: https://console.groq.com/keys)
LLM_API_KEY=

# Optional overrides (defaults are picked per provider in src/llm/adapter.py)
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Web app only: set ENABLE_LLM=1 to let the app use the key ABOVE (server-side).
# Leave it UNSET on a public deploy — otherwise anyone who visits can spend your
# key. (Visitors can always paste their OWN key in the UI; that path is always on.)
# ENABLE_LLM=1
